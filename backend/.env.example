# Backend environment template
# Copy to backend/.env for manual backend runs:
#   cp backend/.env.example backend/.env

APP_ENV=local

# Manual local backend should use host "localhost".
DATABASE_URL=postgresql+psycopg://wavs:wavs@localhost:5432/wavs

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default admin account created on first startup if missing.
ADMIN_EMAIL=admin@wavs.local
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=System Admin

# Production example values. Uncomment and replace for production deployments.
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://wavs_app:replace-with-a-strong-database-password@db.example.com:5432/wavs
# CORS_ORIGINS=https://app.example.com
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-a-strong-initial-admin-password
# ADMIN_FULL_NAME=System Admin
