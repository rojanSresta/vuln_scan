# WAVS Docker Compose environment template
# Keep this root file because Docker Compose automatically reads .env here.
# Copy it for full-stack Docker runs:
#   cp .env.example .env
#
# For manual non-Docker runs, use:
# - backend/.env.example
# - frontend/.env.example
#
# Production: replace passwords, public URLs, and CORS origins before deploy.

# Runtime profile. Informational for now; useful for deployment tooling.
APP_ENV=local

# Postgres service used by Docker Compose.
POSTGRES_DB=wavs
POSTGRES_USER=wavs
POSTGRES_PASSWORD=wavs

# Backend database connection.
# Docker Compose backend should use host "postgres".
DATABASE_URL=postgresql+psycopg://wavs:wavs@postgres:5432/wavs

# Browser origins allowed to call the API. Comma-separated, no spaces.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend build-time settings. The browser must be able to reach this API URL.
REACT_APP_API_URL=http://localhost:8000
REACT_APP_TOKEN_KEY=wavs_token
REACT_APP_ADMIN_TOKEN_KEY=wavs_admin_token

# Default admin account created on first startup if missing.
ADMIN_EMAIL=admin@wavs.local
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=System Admin
