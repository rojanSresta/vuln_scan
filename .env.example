# Copy to .env and adjust if needed: cp .env.example .env

# Frontend (browser must reach the API on the host)
REACT_APP_API_URL=http://localhost:8000

# Backend
DATABASE_URL=postgresql+psycopg://wavs:wavs@postgres:5432/wavs
TOKEN_KEY=wavs_token
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default admin (created on first startup if missing)
ADMIN_EMAIL=admin@wavs.local
ADMIN_PASSWORD=admin12345
ADMIN_FULL_NAME=System Admin
