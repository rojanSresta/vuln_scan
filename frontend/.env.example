# Frontend environment template
# Copy to frontend/.env for manual React development:
#   cp frontend/.env.example frontend/.env
#
# React only exposes variables prefixed with REACT_APP_.

REACT_APP_API_URL=http://localhost:8000
REACT_APP_TOKEN_KEY=wavs_token
REACT_APP_ADMIN_TOKEN_KEY=wavs_admin_token

# Production example values. Uncomment and replace for production builds.
# REACT_APP_API_URL=https://api.example.com
# REACT_APP_TOKEN_KEY=wavs_token
# REACT_APP_ADMIN_TOKEN_KEY=wavs_admin_token
